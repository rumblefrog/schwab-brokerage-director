# SnapTrade credentials — get from https://dashboard.snaptrade.com/
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# SnapTrade user identifiers — produced by `python scripts/setup_snaptrade.py`
SNAPTRADE_USER_ID=self
SNAPTRADE_USER_SECRET=

# Discord channel webhook — Server Settings → Integrations → Webhooks → Copy URL
DISCORD_WEBHOOK_URL=
